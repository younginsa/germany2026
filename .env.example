# ─── Supabase ────────────────────────────────────────────────
# 값이 비어 있으면 앱은 데모 모드(로컬 시드 데이터)로 실행됩니다.
# Supabase 프로젝트 → Settings → API 에서 확인하세요.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Google Maps ─────────────────────────────────────────────
# 값이 비어 있으면 지도 페이지는 프리뷰(정적) 모드로 표시됩니다.
# Google Cloud Console → Maps JavaScript API + Places API 활성화 필요.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
